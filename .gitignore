# User settings (keep private)
.claude/settings.local.json

# Output folder contents (user's work products)
# Structure is preserved via .gitkeep files
output/**
!output/.gitkeep
!output/**/.gitkeep

# Projects folder contents (project-specific work)
# Each subfolder is a user's project workspace
projects/**
!projects/.gitkeep
!projects/**/.gitkeep

# Temp files (staging area, safe to delete)
temp-files/**
!temp-files/.gitkeep

# macOS
.DS_Store

# IDE
.idea/
.vscode/

# Temporary files
*.tmp
*.swp
*~
