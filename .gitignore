# User settings (keep private)
.claude/settings.local.json

# Personal folder contents (all user-generated work)
# Structure is preserved via .gitkeep files
personal/**
!personal/.gitkeep
!personal/**/.gitkeep

# Temp files (input staging area, safe to delete)
temp-files/**
!temp-files/.gitkeep

# macOS
.DS_Store

# IDE
.idea/
.vscode/

# Temporary files
*.tmp
*.swp
*~
